PORT=4000
NODE_ENV=development
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=7d
SKIP_DB=false

# --- MongoDB ---
# Local (default for development)
MONGODB_URI=mongodb://127.0.0.1:27017/rack-n-roll

# MongoDB Atlas (staging/production)
# Use a dedicated DB user password from Atlas → Database Access (not your Atlas login).
# URL-encode special characters in the password (@, #, /, etc.).
# MONGODB_URI=mongodb+srv://<db_user>:<db_password>@rack-roll-cluster.l2t7k.mongodb.net/rack-n-roll?retryWrites=true&w=majority&appName=Rack-Roll-Cluster

# --- CORS (Expo web / browser clients) ---
# Comma-separated origins. Required in production if you ship the Expo web build.
# CORS_ORIGINS=http://localhost:8081,http://localhost:19006,https://your-frontend.example.com

MAIL_DELIVERY_MODE=log
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Rack-N-Roll
PASSWORD_RESET_PIN_TTL_MINUTES=15
PASSWORD_RESET_PIN_COOLDOWN_SECONDS=60
PASSWORD_RESET_PIN_MAX_ATTEMPTS=5
PASSWORD_RESET_SESSION_TTL_MINUTES=10
