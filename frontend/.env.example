# Local dev: "auto" picks the right host per platform (recommended)
EXPO_PUBLIC_API_BASE_URL=auto

# Or set explicitly (required if auto cannot detect your machine):
# EXPO_PUBLIC_API_BASE_URL=http://localhost:4000
# EXPO_PUBLIC_API_BASE_URL=http://YOUR_LAN_IP:4000

# Production API is set in eas.json for EAS builds (preview + production profiles).
# EXPO_PUBLIC_API_BASE_URL=https://rack-n-roll.onrender.com
#
# Web deploy (npm run build:web): set these before building, or in your host's env UI.
# Defaults to https://rack-n-roll.onrender.com when EXPO_PUBLIC_API_BASE_URL is unset.
# EXPO_PUBLIC_API_BASE_URL=https://rack-n-roll.onrender.com
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Google OAuth client IDs (from Google Cloud Console)
# Web client ID must match backend GOOGLE_CLIENT_ID for ID token verification.
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com
#
# Android native sign-in requires a development/preview/production build (not Expo Go).
# Register SHA-1 + package com.dhanushcharipally.racknroll on the Android OAuth client.
# Run: npm run android:sha1  (prints local debug SHA-1 fingerprints)
#
# You need EVERY SHA-1 that signs a build you install:
# - Local expo run:android → project debug.keystore (see npm run android:sha1)
# - EAS preview/production → Expo upload keystore SHA-1 (Expo dashboard → Credentials)
# - Play Store installs → Play Console → App signing → App signing key certificate SHA-1
#
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID must be the Web application client ID (same as backend
# GOOGLE_CLIENT_ID). Do NOT use the Android OAuth client ID as the web client ID.
