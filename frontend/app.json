{
  "expo": {
    "name": "Rack-n-Roll",
    "slug": "rack-n-roll",
    "version": "1.1.0",
    "orientation": "default",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "@react-native-community/datetimepicker",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "36a3387c-fc35-4a53-93a6-306f4dd04fab"
      }
    },
    "android": {
      "versionCode": 2,
      "package": "com.dhanushcharipally.racknroll"
    }
  }
}
